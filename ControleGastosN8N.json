        "jsCode": "const raw = $input.first().json.output;\n\n// Remove ```json e ```\nconst clean = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n// Converte para objeto\nconst data = JSON.parse(clean);\n\nreturn [{ json: data }];"
