      "parameters": {
        "jsCode": "const valorTotal = $input.first().json.valorTotal;\nconst vezes = $input.first().json.vezes;\nconst dataBase = new Date($input.first().json.data);\n\nconst valorParcela = Number((valorTotal / vezes).toFixed(2));\n\nlet parcelas = [];\n\nfor (let i = 0; i < vezes; i++) {\n    let novaData = new Date(dataBase);\n    novaData.setMonth(novaData.getMonth() + i);\n\n    parcelas.push({\n        data: novaData.toISOString().split('T')[0],\n        valor: valorParcela,\n        descricao: $input.first().json.detalhes,\n        tipo: \"despesa\",\n        categoria: $input.first().json.categoria\n    });\n}\n\n// 👇 IMPORTANTE: retornar como 1 item contendo array\nreturn [\n  {\n    JSON: parcelas\n  }\n];"
      },
