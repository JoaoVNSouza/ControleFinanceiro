    {
      "parameters": {
        "language": "python",
        "pythonCode": "from datetime import datetime, timedelta\n\nfor item in _input.all():\n    # Converte string para datetime\n    data_original = datetime.fromisoformat(item.json[\"data\"])\n    \n    # Soma 1 hora\n    nova_data = data_original + timedelta(hours=1)\n    \n    # Formata: Ano-mes-dia horas:minutos:segundos\n    item.json[\"data\"] = nova_data.strftime(\"%d/%m/%Y\")\n\nreturn _input.all()"
      },
